<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mubashir Store - Premium Online Shopping</title>
    <link rel="stylesheet" href="css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <!-- Navigation Bar -->
    <nav class="navbar">
        <div class="container">
            <div class="nav-wrapper">
                <div class="logo">
                    <i class="fas fa-shopping-bag"></i>
                    <span>Mubashir Store</span>
                </div>
                <ul class="nav-menu">
                    <li><a href="index.html" class="active">Home</a></li>
                    <li><a href="shop.html">Shop</a></li>
                    <li><a href="#about">About</a></li>
                    <li><a href="#contact">Contact</a></li>
                </ul>
                <div class="nav-icons">
                    <a href="#" class="icon-link">
                        <i class="fas fa-search"></i>
                    </a>
                    <a href="#" class="icon-link">
                        <i class="fas fa-user"></i>
                    </a>
                    <a href="cart.html" class="icon-link cart-icon">
                        <i class="fas fa-shopping-cart"></i>
                        <span class="cart-count" id="cartCount">0</span>
                    </a>
                </div>
                <div class="hamburger">
                    <span></span>
                    <span></span>
                    <span></span>
                </div>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero">
        <div class="hero-content">
            <h1>Welcome to Mubashir Store</h1>
            <p>Discover Premium Quality Products at Best Prices</p>
            <a href="shop.html" class="btn btn-primary">Shop Now</a>
        </div>
        <div class="hero-image">
            <img src="https://via.placeholder.com/500x400?text=Premium+Products" alt="Hero Image">
        </div>
    </section>

    <!-- Featured Products -->
    <section class="featured-products">
        <div class="container">
            <h2>Featured Products</h2>
            <div class="products-grid" id="featuredProducts">
                <!-- Products will be loaded here by JavaScript -->
            </div>
        </div>
    </section>

    <!-- Categories Section -->
    <section class="categories">
        <div class="container">
            <h2>Shop by Category</h2>
            <div class="categories-grid">
                <div class="category-card">
                    <i class="fas fa-laptop"></i>
                    <h3>Electronics</h3>
                    <p>Latest Gadgets & Devices</p>
                </div>
                <div class="category-card">
                    <i class="fas fa-shirt"></i>
                    <h3>Fashion</h3>
                    <p>Trendy Clothes & Accessories</p>
                </div>
                <div class="category-card">
                    <i class="fas fa-home"></i>
                    <h3>Home & Living</h3>
                    <p>Furniture & Home Essentials</p>
                </div>
                <div class="category-card">
                    <i class="fas fa-dumbbell"></i>
                    <h3>Sports</h3>
                    <p>Fitness & Sports Equipment</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Testimonials -->
    <section class="testimonials">
        <div class="container">
            <h2>What Our Customers Say</h2>
            <div class="testimonials-grid">
                <div class="testimonial-card">
                    <div class="stars">
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                    </div>
                    <p>"Excellent quality products and fast delivery. Highly recommended!"</p>
                    <h4>Ahmed Ali</h4>
                    <span>Verified Buyer</span>
                </div>
                <div class="testimonial-card">
                    <div class="stars">
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                    </div>
                    <p>"Great customer service and amazing prices. Will shop again!"</p>
                    <h4>Fatima Khan</h4>
                    <span>Verified Buyer</span>
                </div>
                <div class="testimonial-card">
                    <div class="stars">
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                    </div>
                    <p>"Best online shopping experience. Delivery was on time!"</p>
                    <h4>Muhammad Hassan</h4>
                    <span>Verified Buyer</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-section">
                    <h3>About Us</h3>
                    <p>Mubashir Store is your one-stop destination for premium quality products at competitive prices.</p>
                </div>
                <div class="footer-section">
                    <h3>Quick Links</h3>
                    <ul>
                        <li><a href="#">About</a></li>
                        <li><a href="#">Products</a></li>
                        <li><a href="#">Blog</a></li>
                        <li><a href="#">Contact</a></li>
                    </ul>
                </div>
                <div class="footer-section">
                    <h3>Contact Info</h3>
                    <p>Email: info@mubashirstore.com</p>
                    <p>Phone: +92 300 1234567</p>
                    <p>Address: Karachi, Pakistan</p>
                </div>
                <div class="footer-section">
                    <h3>Follow Us</h3>
                    <div class="social-links">
                        <a href="#"><i class="fab fa-facebook"></i></a>
                        <a href="#"><i class="fab fa-twitter"></i></a>
                        <a href="#"><i class="fab fa-instagram"></i></a>
                        <a href="#"><i class="fab fa-linkedin"></i></a>
                    </div>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2024 Mubashir Store. All rights reserved. | Designed by Muhammad Mubashir</p>
            </div>
        </div>
    </footer>

    <script src="js/script.js"></script>
</body>
</html>
